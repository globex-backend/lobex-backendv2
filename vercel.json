{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/frontend/index_v5.html" },
    { "src": "/login", "dest": "/frontend/login_v5.html" },
    { "src": "/intake", "dest": "/frontend/mna_portal_v5.html" },
    { "src": "/consent", "dest": "/frontend/consent_monitoring.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
